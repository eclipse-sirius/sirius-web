<plugin
      name="%pluginName"
      id="sirius-components-view-diagram-edit"
      version="1.0.0"
      provider-name="%providerName"
      class="org.eclipse.sirius.components.view.diagram.provider.DiagramEditPlugin$Implementation">

   <requires>
      <import plugin="org.eclipse.core.runtime"/>
      <import plugin="sirius-components-view-diagram" export="true"/>
      <import plugin="org.eclipse.emf.edit" export="true"/>
      <import plugin="sirius-components-view" export="true"/>
      <import plugin="sirius-components-view-edit" export="true"/>
   </requires>

   <runtime>
      <library name=".">
         <export name="*"/>
      </library>
   </runtime>

   <extension point="org.eclipse.emf.edit.itemProviderAdapterFactories">
      <!-- @generated diagram -->
      <factory
            uri="http://www.eclipse.org/sirius-web/diagram"
            class="org.eclipse.sirius.components.view.diagram.provider.DiagramItemProviderAdapterFactory"
            supportedTypes=
              "org.eclipse.emf.edit.provider.IEditingDomainItemProvider
               org.eclipse.emf.edit.provider.IStructuredItemContentProvider
               org.eclipse.emf.edit.provider.ITreeItemContentProvider
               org.eclipse.emf.edit.provider.IItemLabelProvider
               org.eclipse.emf.edit.provider.IItemPropertySource"/>
   </extension>

   <extension point="org.eclipse.emf.edit.childCreationExtenders">
      <!-- @generated diagram -->
      <extender
            uri="http://www.eclipse.org/sirius-web/view"
            class="org.eclipse.sirius.components.view.diagram.provider.DiagramItemProviderAdapterFactory$ViewChildCreationExtender"/>
   </extension>

</plugin>
