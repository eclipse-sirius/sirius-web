<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="02-add-semantic-data-dependency-table" author="gdaniel">
        <createTable tableName="semantic_data_dependency">
            <column name="semantic_data_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="library_id" type="UUID">
				<constraints nullable="false"/>
			</column>
			<column name="index" type="INTEGER">
                <constraints nullable="false" />
            </column>
        </createTable>
		<addForeignKeyConstraint baseTableName="semantic_data_dependency" baseColumnNames="semantic_data_id" constraintName="fk_semantic_data_id" referencedTableName="semantic_data" referencedColumnNames="id" onDelete="CASCADE"/>
		<addForeignKeyConstraint baseTableName="semantic_data_dependency" baseColumnNames="library_id" constraintName="fk_library_id" referencedTableName="library" referencedColumnNames="id" onDelete="CASCADE"/>
		<addPrimaryKey tableName="semantic_data_dependency" columnNames="semantic_data_id,library_id" />
    </changeSet>
</databaseChangeLog>