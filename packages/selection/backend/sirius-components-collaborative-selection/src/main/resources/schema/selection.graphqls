extend type Subscription {
  selectionDialogTreeEvent(input: SelectionDialogTreeEventInput!): TreeEventPayload!
}

input SelectionDialogTreeEventInput {
  id: ID!
  editingContextId: ID!
  representationId: String!
}

type SelectionDescription implements RepresentationDescription {
  id: ID!
  label: String!
  dialog(variables: [SelectionDialogVariable!]!): SelectionDescriptionDialog!
  dialogSelectionRequiredWithSelectionStatusMessage(treeSelection: [String!]!): String!
  treeDescription: TreeDescription!
  multiple: Boolean!
  optional: Boolean!
}

input SelectionDialogVariable {
  name: String!
  value: String!
}

type SelectionDescriptionDialog {
  titles: SelectionDescriptionDialogTitles!
  description: String!
  noSelectionAction: SelectionDescriptionDialogAction!
  withSelectionAction: SelectionDescriptionDialogAction!
  statusMessages: SelectionDescriptionDialogStatusMessages!
  confirmButtonLabels: SelectionDescriptionDialogConfirmButtonLabels!
}

type SelectionDescriptionDialogTitles {
  defaultTitle: String!
  noSelectionTitle: String!
  withSelectionTitle: String!
}

type SelectionDescriptionDialogAction {
  label: String!
  description: String!
}

type SelectionDescriptionDialogStatusMessages {
  noSelectionActionStatusMessage: String!
  selectionRequiredWithoutSelectionStatusMessage: String!
}

type SelectionDescriptionDialogConfirmButtonLabels {
  noSelectionConfirmButtonLabel: String!
  selectionRequiredWithoutSelectionConfirmButtonLabel: String!
  selectionRequiredWithSelectionConfirmButtonLabel: String!
}
